# ══════════════════════════════════════════════════════════════════════════════
# AI Resume Tailor — Environment Variables Template
# Скопируй этот файл в .env и заполни свои значения
# ══════════════════════════════════════════════════════════════════════════════

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Получить на: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro-latest

# ─── Google Docs API ──────────────────────────────────────────────────────────
# Путь к файлу credentials.json из Google Cloud Console
# (Service Account или OAuth 2.0)
GOOGLE_CREDENTIALS_PATH=./backend/credentials.json

# ID шаблона резюме в Google Docs (не менять без необходимости)
GDOC_TEMPLATE_ID=1A0Iv8sVOXVj_cnKChDZtYfFBCJFetD6Yn9AfeXfPCGo

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./backend/data/applications.db

# ─── App Settings ─────────────────────────────────────────────────────────────
# Режим: "mock" — без реального Gemini (для разработки)
#         "live" — с реальным Gemini API
APP_MODE=mock

DEBUG=true
CORS_ORIGINS=http://localhost:5173
